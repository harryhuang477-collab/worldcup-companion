# ─── Football Data API ───────────────────────────────────────────────────────
# Sign up free at https://dashboard.api-football.com/register
# Free tier: 100 requests/day — enough for personal use with smart polling
FOOTBALL_API_KEY=

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Choose one: anthropic | openai | google | openrouter
LLM_PROVIDER=anthropic

# Anthropic (default) — sign up at https://console.anthropic.com
# Default model: claude-haiku-4-5 (fast + cheap)
ANTHROPIC_API_KEY=

# OpenAI — sign up at https://platform.openai.com
# Default model: gpt-4o-mini
OPENAI_API_KEY=

# Google Gemini — sign up at https://aistudio.google.com
# Default model: gemini-1.5-flash-latest
GEMINI_API_KEY=

# OpenRouter (one key, 300+ models) — sign up at https://openrouter.ai
# Default model: meta-llama/llama-3.1-8b-instruct:free  (free!)
OPENROUTER_API_KEY=

# ─── Optional: override the default model for your chosen provider ────────────
# Examples:
#   claude-sonnet-4-6   (anthropic)
#   gpt-4o              (openai)
#   gemini-1.5-pro      (google)
#   anthropic/claude-3-haiku  (openrouter)
LLM_MODEL=
